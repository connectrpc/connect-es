    "conformance:safari:callback": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "conformance:chrome:promise": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "conformance:chrome:callback": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "conformance:firefox:promise": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "conformance:firefox:callback": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "conformance:node:promise": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "conformance:node:callback": {
      "cache": false,
      "dependsOn": ["^build"]
    }
  }
}
