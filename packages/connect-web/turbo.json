{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "conformance": {
      "dependsOn": ["conformance:node:promise", "conformance:node:callback"]
    },
    "conformance:safari:promise": {
      "cache": false,
      "dependsOn": ["^build"]
