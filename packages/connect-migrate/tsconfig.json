{
  "include": ["src/**/*.ts"],
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    // required for jscodeshift
    "esModuleInterop": true,
    // This package is CommonJS
    "verbatimModuleSyntax": false,
    "module": "CommonJS",
    "moduleResolution": "Node10"
  }
}
