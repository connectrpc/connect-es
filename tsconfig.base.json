{
  "compilerOptions": {
    "target": "es2017",
    "lib": [
      "ES2017",
      // DOM for the fetch and streams API
      "DOM",
      // ES2018.AsyncIterable for AsyncIterator
      "ES2018.AsyncIterable",
      // ES2018.AsyncGenerator for AsyncGenerator
      "ES2018.AsyncGenerator",
      // ES2018.Promise for Promise.prototype.finally
      "ES2018.Promise",
      // ES2019.Array for Array.prototype.flatMap
      "ES2019.Array",
      // ES2019.Object for Object.fromEntries
      "ES2019.Object",
      // ES2020.Promise for Promise.allSettled
      "ES2020.Promise",
    ],
    "declaration": true,
    // We don't have dependencies that require interop
    "esModuleInterop": false,
    // As strict as possible
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    // We're building with Node16 module resolution
    "moduleResolution": "Node16",
    "module": "Node16",
    "verbatimModuleSyntax": true,
    "skipLibCheck": false,
    // Silence TS 6.0 deprecation of moduleResolution=node10, which some builds still rely on.
    "ignoreDeprecations": "6.0",
  },
}
